# 🌐 Modaribi DZ - Database Configuration
# =========================================
# PRODUCTION (Vercel):
#   DATABASE_URL is set automatically via Neon integration.
#   No need to modify anything.
#
# LOCAL DEVELOPMENT:
#   Option 1: Use Neon (recommended)
#     Get your DATABASE_URL from https://console.neon.tech
#     Then set: DATABASE_URL="postgresql://user:pass@ep-xxx.region.neon.tech/dbname?sslmode=require"
#
#   Option 2: Install PostgreSQL locally
#     winget install PostgreSQL.PostgreSQL
#     Then set: DATABASE_URL="postgresql://postgres:postgres@localhost:5432/modaribi-dz"
#
#   Option 3: Use Docker
#     docker run -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres:16
#     Then set: DATABASE_URL="postgresql://postgres:postgres@localhost:5432/modaribi-dz"
#
# After setting DATABASE_URL, run:
#   npx prisma migrate dev
#   npx prisma db seed

SESSION_SECRET="modaribi-dz-v2-secret-key-change-in-prod-2026"
